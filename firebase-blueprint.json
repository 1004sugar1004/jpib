{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores private user-specific information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "class": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher"] },
        "score": { "type": "integer" },
        "monthlyScore": { "type": "integer" },
        "lastActiveMonth": { "type": "string" },
        "completedStudyItems": { "type": "array", "items": { "type": "string" } },
        "photoURL": { "type": "string" },
        "dailyXP": { "type": "integer" },
        "lastXPDate": { "type": "string" },
        "dailyScore": { "type": "integer" },
        "gameTickets": { "type": "integer" }
      },
      "required": ["uid", "name", "grade", "class", "role"]
    },
    "publicProfiles": {
      "title": "Public Profile",
      "description": "Non-sensitive user info for rankings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "class": { "type": "string" },
        "score": { "type": "integer" },
        "monthlyScore": { "type": "integer" },
        "lastActiveMonth": { "type": "string" },
        "dailyScore": { "type": "integer" },
        "lastXPDate": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "name", "grade", "class", "score"]
    },
    "activityLogs": {
      "title": "Activity Log",
      "description": "Logs of user activities for anti-abuse.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "grade": { "type": "string" },
        "class": { "type": "string" },
        "activityType": { "type": "string" },
        "timestamp": { "type": "integer" },
        "duration": { "type": "integer" },
        "accuracy": { "type": "number" },
        "xpGained": { "type": "integer" },
        "isSuspicious": { "type": "boolean" }
      },
      "required": ["uid", "activityType", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Private user profiles."
    },
    "/publicProfiles/{userId}": {
      "schema": "publicProfiles",
      "description": "Public user profiles for rankings."
    },
    "/activityLogs/{logId}": {
      "schema": "activityLogs",
      "description": "Logs of user activities."
    },
    "/reflections/{userId}": {
      "schema": "object",
      "description": "User reflection data."
    },
    "/atl/{userId}": {
      "schema": "object",
      "description": "User ATL skill data."
    }
  }
}
