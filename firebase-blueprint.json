{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores private user-specific information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "class": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher"] },
        "score": { "type": "integer" },
        "monthlyScore": { "type": "integer" },
        "lastActiveMonth": { "type": "string" },
        "completedStudyItems": { "type": "array", "items": { "type": "string" } },
        "photoURL": { "type": "string" },
        "dailyXP": { "type": "integer" },
        "lastXPDate": { "type": "string" },
        "dailyScore": { "type": "integer" },
        "gameTickets": { "type": "integer" }
      },
      "required": ["uid", "name", "grade", "class", "role"]
    },
    "publicProfiles": {
      "title": "Public Profile",
      "description": "Non-sensitive user info for rankings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "class": { "type": "string" },
        "score": { "type": "integer" },
        "monthlyScore": { "type": "integer" },
        "lastActiveMonth": { "type": "string" },
        "dailyScore": { "type": "integer" },
        "lastXPDate": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "name", "grade", "class", "score"]
    },
    "activityLogs": {
      "title": "Activity Log",
      "description": "Logs of user activities for anti-abuse.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "grade": { "type": "string" },
        "class": { "type": "string" },
        "activityType": { "type": "string" },
        "timestamp": { "type": "integer" },
        "duration": { "type": "integer" },
        "accuracy": { "type": "number" },
        "xpGained": { "type": "integer" },
        "isSuspicious": { "type": "boolean" }
      },
      "required": ["uid", "activityType", "timestamp"]
    },
    "feedback": {
      "title": "User Feedback",
      "description": "Feedback from users about the site and games.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "grade": { "type": "string" },
        "class": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "integer" }
      },
      "required": ["uid", "content", "timestamp"]
    },
    "ibBoardPosts": {
      "title": "IB Board Post",
      "description": "Posts created by users on the IB inquiry board.",
      "type": "object",
      "properties": {
        "topicId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "gradeClass": { "type": "string" },
        "avatarSvg": { "type": "string" },
        "content": { "type": "string" },
        "bgColor": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "integer" }
      },
      "required": ["topicId", "userId", "content", "createdAt"]
    },
    "sharedCertificates": {
      "title": "Shared Certificate",
      "description": "Certificates or images shared to the public gallery.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "gradeClass": { "type": "string" },
        "avatarSvg": { "type": "string" },
        "caricatureSvg": { "type": "string" },
        "imageUrl": { "type": "string" },
        "caption": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "integer" }
      },
      "required": ["userId", "caption", "createdAt"]
    },
    "gameScores": {
      "title": "Game Score",
      "description": "Leaderboard scores for each game.",
      "type": "object",
      "properties": {
        "gameId": { "type": "string" },
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "grade": { "type": "string" },
        "class": { "type": "string" },
        "score": { "type": "integer" },
        "timestamp": { "type": "integer" }
      },
      "required": ["gameId", "uid", "userName", "score", "timestamp"]
    },
    "bingoRooms": {
      "title": "Bingo Room",
      "description": "Real-time multiplayer bingo game rooms.",
      "type": "object",
      "properties": {
        "roomId": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "setup", "playing", "ended"] },
        "hostId": { "type": "string" },
        "hostName": { "type": "string" },
        "players": { "type": "object" },
        "calledWords": { "type": "array", "items": { "type": "string" } },
        "currentTurn": { "type": "string" },
        "turnOrder": { "type": "array", "items": { "type": "string" } },
        "winnerId": { "type": "string" },
        "winnerName": { "type": "string" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["roomId", "status", "hostId", "hostName", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Private user profiles."
    },
    "/publicProfiles/{userId}": {
      "schema": "publicProfiles",
      "description": "Public user profiles for rankings."
    },
    "/activityLogs/{logId}": {
      "schema": "activityLogs",
      "description": "Logs of user activities."
    },
    "/feedback/{feedbackId}": {
      "schema": "feedback",
      "description": "User feedback submissions."
    },
    "/reflections/{userId}": {
      "schema": "object",
      "description": "User reflection data."
    },
    "/atl/{userId}": {
      "schema": "object",
      "description": "User ATL skill data."
    },
    "/ibBoardPosts/{docId}": {
      "schema": "ibBoardPosts",
      "description": "IB Board inquiry post entries."
    },
    "/sharedCertificates/{docId}": {
      "schema": "sharedCertificates",
      "description": "User-shared certificates gallery entries."
    },
    "/gameScores/{docId}": {
      "schema": "gameScores",
      "description": "Leaderboard scores for each game."
    },
    "/bingoRooms/{roomId}": {
      "schema": "bingoRooms",
      "description": "Real-time multiplayer bingo game rooms."
    }
  }
}
