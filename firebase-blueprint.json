{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user-specific information like grade and class.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address."
        },
        "grade": {
          "type": "integer",
          "description": "The user's grade level."
        },
        "class": {
          "type": "integer",
          "description": "The user's class number."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The last time the profile was updated."
        }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Individual user profiles stored by their UID."
    }
  }
}
