rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - name: string (required, min 1, max 50) - The user's full name.
    //   - grade: string (required, min 1, max 10) - The user's grade level.
    //   - class: string (required, min 1, max 10) - The user's class number.
    //   - role: string (required, enum: ['student', 'teacher']) - The user's role.
    //   - score: number (required, min 0) - The user's total quiz score.
    //   - lastQuizDate: string (optional, ISO 8601) - The timestamp of the student's last quiz attempt.
    //   - streak: number (optional, min 0) - The student's max quiz streak.
    //
    // Collection: reflections
    // Document ID: {userId}
    // Fields: Map of question strings to answer strings.
    //
    // Collection: atl
    // Document ID: {userId}
    // Fields: Map of skill keys to rating numbers (1-3).
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "1004sugar1004@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'grade', 'class', 'score', 'role']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             data.grade is string && data.grade.size() > 0 && data.grade.size() <= 10 &&
             data.class is string && data.class.size() > 0 && data.class.size() <= 10 &&
             data.role in ['student', 'teacher'] &&
             data.score is number && data.score >= 0 &&
             (!('streak' in data) || (data.streak is number && data.streak >= 0));
    }

    function isValidReflection(data) {
      // Reflections are a map of strings
      return data.keys().size() <= 20; // Limit number of entries
    }

    function isValidATL(data) {
      // ATL ratings are numbers 1-3
      return data.keys().size() <= 50;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /reflections/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidReflection(request.resource.data);
    }

    match /atl/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidATL(request.resource.data);
    }
  }
}
