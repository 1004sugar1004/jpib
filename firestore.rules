rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - grade: string (required) - e.g., "3학년"
    //   - class: string (required) - e.g., "5반"
    //   - role: string (required) - "student" or "teacher"
    //   - score: number
    //   - monthlyScore: number
    //   - photoURL: string
    //
    // Collection: publicProfiles
    // Document ID: userId
    // Fields: name, grade, class, score, monthlyScore, photoURL
    //
    // Collection: activityLogs
    // Document ID: auto-generated
    // Fields: uid, userName, grade, class, activityType, timestamp, duration, accuracy, xpGained
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             request.auth.token.email == "1004sugar1004@gmail.com" &&
             request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'grade', 'class', 'role']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.grade is string && data.grade.size() > 0 && data.grade.size() < 20 &&
             data.class is string && data.class.size() > 0 && data.class.size() < 20 &&
             data.role in ['student', 'teacher'];
    }

    function isValidPublicProfile(data) {
      return data.keys().hasAll(['uid', 'name', 'grade', 'class', 'score']) &&
             data.uid is string &&
             data.name is string &&
             data.grade is string &&
             data.class is string &&
             data.score is number;
    }

    function isValidActivityLog(data) {
      return data.keys().hasAll(['uid', 'activityType', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.timestamp is int;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false;
    }

    match /publicProfiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidPublicProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidPublicProfile(request.resource.data);
      allow delete: if false;
    }

    match /activityLogs/{logId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid));
      allow create: if isAuthenticated() && isValidActivityLog(request.resource.data);
      allow update, delete: if false;
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /reflections/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /atl/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
