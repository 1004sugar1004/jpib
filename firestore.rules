rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - The unique identifier for the user.
    //   - displayName: string (optional) - The user's display name.
    //   - email: string (required) - The user's email address.
    //   - grade: number (optional) - The user's grade level.
    //   - class: number (optional) - The user's class number.
    //   - updatedAt: timestamp (optional) - The last time the profile was updated.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('grade' in data) || (data.grade is int && data.grade >= 1 && data.grade <= 12)) &&
             (!('class' in data) || (data.class is int && data.class >= 1 && data.class <= 30)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false; // Users cannot delete their profiles for now
    }
  }
}
